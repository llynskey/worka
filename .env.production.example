POSTGRES_DB=worka
POSTGRES_USER=worka
POSTGRES_PASSWORD=replace-with-a-long-random-password

JwtSecret=replace-with-a-long-random-secret
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=worka;Username=worka;Password=replace-with-a-long-random-password

# Caddy HTTPS.
# Use :80 while testing on a raw IP. Once DNS points at the VPS, use your domain:
# SITE_ADDRESS=worka.example.com
# SITE_ADDRESS=worka.example.com, www.worka.example.com
SITE_ADDRESS=:80

# Payment rollout settings.
Stripe__SecretKey=sk_live_replace_me
Stripe__WebhookSecret=whsec_replace_me
Stripe__ConnectClientId=ca_replace_me
Stripe__Currency=gbp
Stripe__DefaultCountry=GB
Worka__ServiceFeePercent=10
Worka__ServiceFeeMinimum=2

# --- Self-hosted mail server (docker-mailserver) ---
# Passwords for the mailboxes auto-provisioned on first boot. Use long, unique
# values. These are also the IMAP login passwords for the mail apps.
MAIL_NOREPLY_PASSWORD=replace-with-a-long-random-password
MAIL_SUPPORT_PASSWORD=replace-with-a-long-random-password
MAIL_PROS_PASSWORD=replace-with-a-long-random-password

# The API relays through the mail container by default (see docker-compose.yml).
# Its password is taken from MAIL_NOREPLY_PASSWORD above — no need to repeat it.
# Override Smtp__Host with an external provider (e.g. Brevo/SMTP2GO) if you ever
# stop self-hosting; then also set Smtp__Username/Smtp__Password explicitly.
# Smtp__Host=mail.fixa.site
# Smtp__Port=587
# Smtp__Username=no-reply@fixa.site
# Smtp__UseSsl=true
Smtp__From=no-reply@fixa.site

# TLS for the mail container comes from Caddy's mail.fixa.site certificate. Only
# override these if Caddy's issuer directory differs (e.g. ZeroSSL fallback):
# MAIL_SSL_CERT_PATH=/etc/caddycerts/caddy/certificates/acme-v02.api.letsencrypt.org-directory/mail.fixa.site/mail.fixa.site.crt
# MAIL_SSL_KEY_PATH=/etc/caddycerts/caddy/certificates/acme-v02.api.letsencrypt.org-directory/mail.fixa.site/mail.fixa.site.key

Worka__PublicUrl=https://fixa.site

# Optional, used by the web build for production address lookup.
# Leave blank to use the early-access OpenStreetMap fallback.
EXPO_PUBLIC_MAPBOX_TOKEN=
